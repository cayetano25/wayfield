# Wayfield Command Center — environment variables
# Copy to .env.local and fill in values before running.

# Full base URL of the platform API (include /api/platform/v1, no trailing slash)
NEXT_PUBLIC_PLATFORM_API_URL=http://localhost:8000/api/platform/v1

# Support tool URL (used in Support section)
NEXT_PUBLIC_SUPPORT_TOOL_URL=https://your-support-tool.com
